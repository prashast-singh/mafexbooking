[Unit]
Description=Mafex Room Booking Frontend (Next.js)
After=network.target mafex-api.service

[Service]
Type=simple
User=mafex
Group=mafex
WorkingDirectory=/opt/mafex/mafexFe-main
Environment=NODE_ENV=production
Environment=PORT=3000
Environment=HOSTNAME=127.0.0.1
ExecStart=/usr/bin/npm run start:prod
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
